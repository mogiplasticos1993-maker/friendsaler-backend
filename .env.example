# ═══════════════════════════════════════════════════════════
#  FRIENDSALER — Variáveis de Ambiente
#  Copie este arquivo e configure no painel do Railway
# ═══════════════════════════════════════════════════════════

# 1. Chave da API do Claude (Anthropic)
#    Pegue em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sua_chave_aqui

# 2. Token do WhatsApp (gerado pela Zenvia ou Meta)
#    Zenvia: painel > Configurações > API Token
#    Meta Cloud API: developers.facebook.com > seu app > WhatsApp
WHATSAPP_TOKEN=seu_token_whatsapp_aqui

# 3. Token de verificação do webhook (você escolhe, qualquer texto)
#    Use o mesmo valor na hora de cadastrar o webhook na Zenvia/Meta
VERIFY_TOKEN=friendsaler_verify_2024

# 4. URL da API de envio do WhatsApp
#    Zenvia: https://api.zenvia.com/v2/channels/whatsapp/messages
#    Meta Cloud API: https://graph.facebook.com/v19.0/SEU_PHONE_ID/messages
WHATSAPP_API_URL=https://graph.facebook.com/v19.0/SEU_PHONE_ID/messages

# 5. Porta (o Railway configura automaticamente, não precisa mudar)
PORT=3000
